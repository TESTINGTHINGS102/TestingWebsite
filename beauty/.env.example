# Backend
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Database (when using MongoDB/PostgreSQL)
# DATABASE_URL=mongodb://mongo:27017/beauty
# DATABASE_URL=postgresql://user:password@postgres:5432/beauty

# JWT (for future auth)
# JWT_SECRET=your-secret-key
# JWT_EXPIRES_IN=7d

# Email (for future newsletters)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# AI Image Generation (OpenAI)
# OPENAI_API_KEY=sk-your-openai-api-key
